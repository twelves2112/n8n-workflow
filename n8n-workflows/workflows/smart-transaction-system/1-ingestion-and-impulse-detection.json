    {
      "parameters": {
        "jsCode": "const tx = $('Code').first().json;        // parser node — confirm it's named \"Code\"\nconst amount = Number(tx.amount) || 0;\n\n// active declarations — name must match your renamed node exactly\nconst declarations = $('Get Pre-declared').all().map(d => d.json.fields || d.json);\n\nlet matchedDeclaration = null;\nfor (const d of declarations) {\n  const expected = Number(d[\"Expected Amount\"]) || 0;\n  if (Math.abs(expected - amount) <= 2000) {\n    matchedDeclaration = d;\n    break;\n  }\n}\nconst isPreDeclared = matchedDeclaration !== null;\n\n// today's debit count — pull explicitly from the count node by name\nconst countToday = $('Count Today\\'s Debits').all().length;\n\nconst category = (tx.category || \"\").toLowerCase();\nconst selfTransfer = tx.self_transfer === true;\n\nlet reasons = [];\nif (!selfTransfer && !isPreDeclared) {\n  if (amount >= 20000) reasons.push(`Large purchase of ₦${amount.toLocaleString()}`);\n  if ([\"shopping\", \"eating out\"].includes(category)) reasons.push(`${tx.category} spend`);\n  if (countToday >= 5) reasons.push(`${countToday} debits already today`);\n}\n\nreturn [{\n  json: {\n    ...tx,\n    is_impulse: reasons.length > 0,\n    impulse_reason: reasons.join(\"; \"),\n    count_today: countToday,\n    is_pre_declared: isPreDeclared,\n    matched_id: matchedDeclaration ? matchedDeclaration.id : null\n  }\n}];"
      },
