    {
      "parameters": {
        "jsCode": "let raw = $input.first().json.content[0].text;\nraw = raw.replace(/```json/g, \"\").replace(/```/g, \"\").trim();\nconst parsed = JSON.parse(raw);\n\n// Translate sender address → clean bank name\nconst senderAddress = $('Gmail Trigger').first().json.from.value[0].address;\n\nconst bankMap = {\n  \"no-reply@opay-nigeria.com\": \"OPay\",\n  \"gens@gtbank.com\": \"GTBank\",\n  \"no-reply@kuda.com\": \"Kuda Bank\",\n  \"e-business@sterling.ng\": \"Sterling Bank\",\n  \"no-reply@ubagroup.com\": \"UBA Bank\",\n};\n\nparsed.bank_from = bankMap[senderAddress] || \"Other\";\n\nreturn parsed;"
      },
