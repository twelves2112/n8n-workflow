    {
      "parameters": {
        "jsCode": "const rows = $input.all().map(i => i.json.fields || i.json);\n\nlet spent = 0, received = 0, impulseCount = 0, txCount = 0;\nconst byCategory = {}, bySpendType = {};\nlet biggest = { amount: 0, merchant: \"\", category: \"\" };\n\nfor (const r of rows) {\n  const amount = Number(r.Amount) || 0;\n  const type = (r.Type || \"\").toLowerCase();\n  if (r[\"Self transfer\"] === true) continue;   // ignore own-account moves\n  txCount++;\n  if (type === \"debit\") {\n    spent += amount;\n    const cat = r.Category || \"Other\";\n    byCategory[cat] = (byCategory[cat] || 0) + amount;\n    const st = r[\"Spend type\"] || \"Unclassified\";\n    bySpendType[st] = (bySpendType[st] || 0) + amount;\n    if (amount > biggest.amount) biggest = { amount, merchant: r.Merchant || \"\", category: cat };\n    if (r[\"Impulse Flag\"] === true) impulseCount++;\n  } else if (type === \"credit\") {\n    received += amount;\n  }\n}\n\nconst fmt = n => \"₦\" + Number(n).toLocaleString();\nconst cats = Object.entries(byCategory).sort((a,b)=>b[1]-a[1]).map(([k,v])=>`${k}: ${fmt(v)}`).join(\", \");\nconst sts  = Object.entries(bySpendType).sort((a,b)=>b[1]-a[1]).map(([k,v])=>`${k}: ${fmt(v)}`).join(\", \");\n\nconst dataSummary =\n`Total spent (excluding self-transfers): ${fmt(spent)}\nTotal received: ${fmt(received)}\nNet: ${fmt(received - spent)}\nTransactions: ${txCount}\nBy category: ${cats || \"none\"}\nBy need/want: ${sts || \"none\"}\nBiggest purchase: ${fmt(biggest.amount)} at ${biggest.merchant} (${biggest.category})\nImpulse-flagged: ${impulseCount}`;\n\nconst past = $('Recommendations (4 weeks)').all()\n  .map(r => (r.json.fields || r.json).Advice)\n  .filter(Boolean)\n  .join(\"\\n---\\n\");\n\nreturn [{ json: { dataSummary, pastAdvice: past || \"No past advice yet.\" } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
